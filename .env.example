# kb2 connects to a Postgres database. Two equivalent forms:

# (a) Single URL — useful when you want full control of params, but special
#     characters (! $ # …) in the password MUST be percent-encoded.
KB2_DATABASE_URL=postgresql+psycopg://surv:surv@localhost:5432/procurement_surv

# (b) Or split fields (kb2.config.Settings builds the URL with quote_plus on
#     the password, so special chars in raw form are fine here):
# KB2_DB_USER=surv
# KB2_DB_PASSWORD=changeme
# KB2_DB_HOST=localhost
# KB2_DB_PORT=5432
# KB2_DB_NAME=procurement_surv
